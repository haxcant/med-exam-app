rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasGlobalConfig() {
      return exists(/databases/$(database)/documents/app_config/global);
    }

    function globalConfig() {
      return get(/databases/$(database)/documents/app_config/global).data;
    }

    // Admin model: create admins/{uid} with { enabled: true }.
    // app_config/global.adminUids is intentionally no longer used, so signed-in users
    // can read the global sync switch without learning the admin UID list.
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.enabled == true;
    }

    function syncEnabled() {
      return hasGlobalConfig()
        && ('syncEnabled' in globalConfig())
        && globalConfig().syncEnabled == true
        && (!('appId' in globalConfig()) || globalConfig().appId == 'med-exam-app');
    }

    function isAllowlisted(userId) {
      return exists(/databases/$(database)/documents/allowlist/$(userId))
        && get(/databases/$(database)/documents/allowlist/$(userId)).data.enabled == true;
    }

    function shortString(value, maxLen) {
      return value is string && value.size() <= maxLen;
    }

    function validGlobalConfig() {
      let d = request.resource.data;
      return d.keys().hasOnly(['appId', 'syncEnabled', 'note'])
        && d.appId == 'med-exam-app'
        && d.syncEnabled is bool
        && (!('note' in d) || shortString(d.note, 500));
    }

    function validAdminDoc(userId) {
      let d = request.resource.data;
      return d.keys().hasOnly(['enabled', 'email', 'role', 'note', 'createdAt', 'createdBy', 'updatedAt', 'updatedBy'])
        && d.enabled is bool
        && (!('email' in d) || shortString(d.email, 254))
        && (!('role' in d) || (d.role in ['owner', 'admin']))
        && (!('note' in d) || shortString(d.note, 500))
        && (!('createdBy' in d) || shortString(d.createdBy, 128))
        && (!('updatedBy' in d) || shortString(d.updatedBy, 128));
    }

    function validAccessRequest(userId) {
      let d = request.resource.data;
      return d.keys().hasOnly([
          'uid', 'email', 'displayName', 'photoURL', 'appId', 'status', 'message',
          'requestedAt', 'updatedAt', 'reviewedAt', 'reviewedBy'
        ])
        && d.uid == userId
        && d.appId == 'med-exam-app'
        && (d.status in ['pending', 'approved', 'rejected'])
        && (!('email' in d) || shortString(d.email, 254))
        && (!('displayName' in d) || shortString(d.displayName, 120))
        && (!('photoURL' in d) || shortString(d.photoURL, 1000))
        && (!('message' in d) || shortString(d.message, 500))
        && (!('reviewedBy' in d) || shortString(d.reviewedBy, 128));
    }

    function validOwnerAccessRequestCreateOrUpdate(userId) {
      let d = request.resource.data;
      return validAccessRequest(userId)
        && d.status == 'pending'
        && (!('reviewedAt' in d))
        && (!('reviewedBy' in d));
    }

    function validAllowlist(userId) {
      let d = request.resource.data;
      return d.keys().hasOnly(['enabled', 'email', 'role', 'approvedAt', 'approvedBy', 'updatedAt', 'updatedBy'])
        && d.enabled is bool
        && (!('email' in d) || shortString(d.email, 254))
        && (!('role' in d) || (d.role in ['user', 'owner', 'admin']))
        && (!('approvedBy' in d) || shortString(d.approvedBy, 128))
        && (!('updatedBy' in d) || shortString(d.updatedBy, 128));
    }

    function validMetaWrite(userId) {
      let d = request.resource.data;
      return d.keys().hasOnly([
          'app', 'type', 'version', 'schemaVersion', 'checksum', 'chunkCount',
          'payloadBytes', 'updatedAt', 'updatedBy', 'updatedUid', 'answeredCount'
        ])
        && d.app == 'med-exam-pwa'
        && d.type == 'full-memory-export'
        && d.version is int
        && d.schemaVersion == 1
        && shortString(d.checksum, 128)
        && d.chunkCount is int
        && d.chunkCount >= 1
        && d.chunkCount <= 10
        && d.payloadBytes is int
        && d.payloadBytes >= 0
        && d.payloadBytes <= 2516582
        && (!('updatedBy' in d) || shortString(d.updatedBy, 254))
        && d.updatedUid == userId
        && d.updatedUid == request.auth.uid
        && d.answeredCount is int
        && d.answeredCount >= 0;
    }

    function validChunkId(chunkId) {
      return chunkId in [
        'chunk_0000', 'chunk_0001', 'chunk_0002', 'chunk_0003', 'chunk_0004',
        'chunk_0005', 'chunk_0006', 'chunk_0007', 'chunk_0008', 'chunk_0009'
      ];
    }

    function validChunkIndex(chunkId, idx) {
      return (chunkId == 'chunk_0000' && idx == 0)
        || (chunkId == 'chunk_0001' && idx == 1)
        || (chunkId == 'chunk_0002' && idx == 2)
        || (chunkId == 'chunk_0003' && idx == 3)
        || (chunkId == 'chunk_0004' && idx == 4)
        || (chunkId == 'chunk_0005' && idx == 5)
        || (chunkId == 'chunk_0006' && idx == 6)
        || (chunkId == 'chunk_0007' && idx == 7)
        || (chunkId == 'chunk_0008' && idx == 8)
        || (chunkId == 'chunk_0009' && idx == 9);
    }

    function validChunkWrite(chunkId) {
      let d = request.resource.data;
      return d.keys().hasOnly(['index', 'checksum', 'data'])
        && d.index is int
        && validChunkIndex(chunkId, d.index)
        && shortString(d.checksum, 128)
        && d.data is string
        && d.data.size() <= 120000;
    }

    function validSmokeWrite(userId) {
      let d = request.resource.data;
      return d.keys().hasOnly(['app', 'type', 'updatedAt', 'updatedBy', 'updatedUid', 'testValue'])
        && d.app == 'med-exam-pwa'
        && d.type == 'diagnostic-smoke-test'
        && (!('updatedBy' in d) || shortString(d.updatedBy, 254))
        && d.updatedUid == userId
        && d.updatedUid == request.auth.uid
        && (!('testValue' in d) || shortString(d.testValue, 200));
    }

    // Global app config. Signed-in users may read only the global app switch fields.
    // Do not store adminUids here; use the private admins/{uid} collection instead.
    match /app_config/global {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if false;
      allow update: if isAdmin() && validGlobalConfig();
      allow delete: if false;
    }

    // Private admin collection. Create admins/{yourUid} from Firebase Console once:
    // { enabled: true, email: "...", role: "owner" }
    // Intentionally no client-side writes: admin membership must be changed from Firebase Console
    // or a trusted server/Admin SDK, not from admin.html.
    match /admins/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if false;
    }

    // Users can create/read their own access request. Admin can list/update/delete all requests.
    match /access_requests/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();

      allow create: if isOwner(userId)
        && syncEnabled()
        && validOwnerAccessRequestCreateOrUpdate(userId);

      allow update: if (
          isAdmin() && validAccessRequest(userId)
        ) || (
          isOwner(userId)
          && syncEnabled()
          && resource.data.uid == userId
          && (resource.data.status in ['pending', 'rejected'])
          && validOwnerAccessRequestCreateOrUpdate(userId)
        );

      allow delete: if isAdmin();
    }

    // Allowlist is readable by the owner, but writable only by admins.
    match /allowlist/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create, update: if isAdmin() && validAllowlist(userId);
      allow delete: if isAdmin();
    }

    // Med exam app: backup metadata.
    match /apps/med-exam-app/users/{userId}/sync/meta {
      allow get, list: if syncEnabled() && isOwner(userId) && isAllowlisted(userId);
      allow create, update: if syncEnabled() && isOwner(userId) && isAllowlisted(userId) && validMetaWrite(userId);
      allow delete: if syncEnabled() && isOwner(userId) && isAllowlisted(userId);
    }

    // Med exam app: chunked backup payload. Hard-limited to chunk_0000 ... chunk_0009.
    match /apps/med-exam-app/users/{userId}/sync_chunks/{chunkId} {
      allow get, list: if syncEnabled() && isOwner(userId) && isAllowlisted(userId);
      allow create, update: if syncEnabled() && isOwner(userId) && isAllowlisted(userId) && validChunkWrite(chunkId);
      allow delete: if syncEnabled() && isOwner(userId) && isAllowlisted(userId) && validChunkId(chunkId);
    }

    // Diagnostic smoke test path. It no longer pollutes sync/meta.
    match /apps/med-exam-app/users/{userId}/diagnostics/smoke {
      allow get: if syncEnabled() && isOwner(userId) && isAllowlisted(userId);
      allow create, update: if syncEnabled() && isOwner(userId) && isAllowlisted(userId) && validSmokeWrite(userId);
      allow delete: if syncEnabled() && isOwner(userId) && isAllowlisted(userId);
    }
  }
}
